{
  "name": "typedclojure-lsp",
  "displayName": "Typed Clojure LSP",
  "description": "Typed Clojure type checking in your editor via LSP",
  "version": "0.0.4",
  "license": "Unlicense",
  "publisher": "olical",
  "repository": {
    "type": "git",
    "url": "https://github.com/Olical/typedclojure-lsp"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:clojure"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "clojure",
        "extensions": [".clj", ".cljs", ".cljc", ".edn", ".bb"],
        "aliases": ["Clojure"]
      }
    ],
    "configuration": {
      "title": "Typed Clojure LSP",
      "properties": {
        "typedclojure-lsp.command": {
          "type": "string",
          "default": ".typedclojure-lsp/start",
          "description": "Command to launch the LSP server. Resolved relative to the workspace root if not absolute. The command's stdout is the LSP transport, so it must not print anything to stdout (logging belongs on stderr)."
        },
        "typedclojure-lsp.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Arguments passed to the launch command."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
